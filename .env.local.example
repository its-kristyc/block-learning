# Copy this file to .env.local and paste your Supabase project's values.
# Find them in Supabase → Project Settings → API.
# The anon key is meant for browsers and is safe to expose (Row Level Security
# is what actually protects the data). .env.local is git-ignored.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
