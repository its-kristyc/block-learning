# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
*.local

# Environment variables / secrets — NEVER commit these
# (matters once you add Supabase or any API keys)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS junk
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# Optional: Claude Code local notes you may not want to share
# (remove this line if you DO want CLAUDE.md tracked — usually you do)
test-results/

# Local image source folders — images are served from Cloudinary, not the repo.
# Keep the folder present via .gitkeep but ignore all working files.
public/images/*
!public/images/.gitkeep
